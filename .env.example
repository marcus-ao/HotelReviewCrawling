# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hotel_reviews
DB_USER=postgres
DB_PASSWORD=your_password

# Chrome调试配置
CHROME_DEBUG_PORT=9222
CHROME_USER_DATA_DIR=C:/selenium/automation_profile

# 爬虫配置
MIN_DELAY=3
MAX_DELAY=6
MAX_RETRIES=3
REQUEST_TIMEOUT=30

# 评论采集配置
# MAX_REVIEWS_PER_HOTEL: 单酒店最终硬上限，动态配额仍会受它兜底约束
MAX_REVIEWS_PER_HOTEL=300
# MIN_REVIEWS_THRESHOLD: 只有评论数达到该阈值的酒店才进入主评论采集队列
MIN_REVIEWS_THRESHOLD=150

# 动态总量配额
# 目标总量 ≈ review_count * REVIEW_TOTAL_SAMPLE_RATIO，再被 MIN/MAX 夹住
REVIEW_TOTAL_SAMPLE_RATIO=0.20
REVIEW_TOTAL_MIN_PER_HOTEL=80
REVIEW_TOTAL_MAX_PER_HOTEL=300

# 负评软目标
# 目标负评 ≈ target_total * REVIEW_NEGATIVE_TARGET_RATIO，再被 MIN/MAX 夹住
REVIEW_NEGATIVE_TARGET_RATIO=0.25
REVIEW_NEGATIVE_MIN_PER_HOTEL=20
REVIEW_NEGATIVE_MAX_PER_HOTEL=80
# 兼容旧逻辑保留；当前实现内部优先使用 REVIEW_NEGATIVE_MAX_PER_HOTEL
REVIEW_NEGATIVE_POOL_LIMIT=100

# 评论质量控制
# 是否启用“长度/信息量分层 + 动态放宽”
REVIEW_QUALITY_STRICT_ENABLE=true
# 正评/负评默认最低有效长度（中文按2单位、英文数字按1单位）
REVIEW_POSITIVE_MIN_EFFECTIVE_LEN=12
REVIEW_NEGATIVE_MIN_EFFECTIVE_LEN=10
# 放宽兜底阶段允许的最短有效长度，仍需命中酒店方面词
REVIEW_POSITIVE_SHORT_FALLBACK_MIN_LEN=8
REVIEW_NEGATIVE_SHORT_FALLBACK_MIN_LEN=6
# 评论质量分层阈值
REVIEW_STRICT_TIER_S_MIN_LEN=40
REVIEW_STRICT_TIER_S_ASPECT_MIN_LEN=25
REVIEW_TIER_B_MIN_LEN=12
REVIEW_TIER_C_MIN_LEN=8
# 按酒店评论量分档时允许的短评论占比上限
REVIEW_SHORT_COMMENT_MAX_RATIO_HIGH=0.10
REVIEW_SHORT_COMMENT_MAX_RATIO_MID=0.20
REVIEW_SHORT_COMMENT_MAX_RATIO_LOW=0.30
# “短但具体”评论的最终占比上限
REVIEW_SPECIFIC_SHORT_MAX_RATIO=0.15
# 严格筛选后若保留数低于 target_count * ratio，则进入放宽阶段
REVIEW_QUALITY_RELAX_TRIGGER_RATIO=0.70

# 翻页停止条件
REVIEW_STAGNANT_PAGE_LIMIT=2

# 批量正向人工辅助配置
# reviews --all 默认是否执行“负评自动 + 正评半自动”的完整流程
REVIEW_BATCH_ALL_WITH_POSITIVE_DEFAULT=true
# 人工接管前，程序滚到底部后先等待多少秒，方便直接点击“下一页”
REVIEW_POSITIVE_MANUAL_PREWAIT_SECONDS=10
# 提示已出现后，若多久无输入则再次提醒一次
REVIEW_POSITIVE_MANUAL_REMINDER_SECONDS=90

# 分层采样策略配置
SAMPLING_POLICY_ENABLED=false
SAMPLING_CITY_COMPENSATION_ENABLED=true
SAMPLING_SPARSE_TIERS=高档型,奢华型
SAMPLING_FLOOR_RATIO_ECONOMY=0.90
SAMPLING_FLOOR_RATIO_COMFORT=0.85
SAMPLING_FLOOR_RATIO_HIGH=0.70
SAMPLING_FLOOR_RATIO_LUXURY=0.60
SAMPLING_BORROW_CAP_RATIO=0.30
SAMPLING_DONOR_GUARD_RATIO=0.10
SAMPLING_THRESHOLD_LADDER=200,150,120

# 验证码配置
CAPTCHA_MAX_RETRIES=3
CAPTCHA_COOLDOWN_SECONDS=180
CAPTCHA_SOLVE_TIMEOUT_SECONDS=180
CAPTCHA_REFRESH_RETRY_LIMIT=5
CAPTCHA_CLICK_SLIDE_REFRESH_THRESHOLD=2
ACCESS_DENIED_MAX_RETRIES=2
ACCESS_DENIED_BACKOFF_MIN_SECONDS=8
ACCESS_DENIED_BACKOFF_MAX_SECONDS=18
HUMAN_INTERACTION_ENABLED=true
SESSION_WARMUP_ENABLED=true
SESSION_IDLE_REWARM_SECONDS=120
REVIEW_MODULE_READY_TIMEOUT_SECONDS=12
REVIEW_REQUEST_CAPTURE_ATTEMPTS=3
REVIEW_POSITIVE_PAGE_LIMIT=15
REVIEW_POSITIVE_MANUAL_DEFAULT_ENABLED=true
REVIEW_POSITIVE_MANUAL_PAGE_LIMIT=20
REVIEW_POSITIVE_AUTO_PAGE_DELAY_MIN_SECONDS=30
REVIEW_POSITIVE_AUTO_PAGE_DELAY_MAX_SECONDS=60
CAPTCHA_DEBUG_ARTIFACTS_ENABLED=false
CAPTCHA_DEBUG_ARTIFACTS_DIR=logs/captcha_artifacts

# 日志配置
LOG_LEVEL=INFO
LOG_DIR=logs
